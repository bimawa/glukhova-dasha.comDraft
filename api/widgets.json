99-4ebb-99bd-aa1d63085762.jpg","url":"https://c-p.rmcdn.net/5479c8026bbe3ca75cc0a82e/1886210/upload-ca9a54de-1364-4ad6-9bcb-c6d3f0116099.jpg","type":"jpg","unscaledUrl":"https://c-p.rmcdn.net/5479c8026bbe3ca75cc0a82e/3936815/Image-4a83280e-3a68-4249-91d0-81a9fadfeac7.jpg","finalUrl":"https://c-p.rmcdn.net/5479c8026bbe3ca75cc0a82e/3936815/Image-9f3e99c3-80ed-486d-af2b-09f4e1fe6a49.jpg","final2xUrl":"https://c-p.rmcdn.net/5479c8026bbe3ca75cc0a82e/3936815/Image-af679a91-dea7-42ea-a2b9-9926daea69c4.jpg","unscaledOptimizedUrl":"https://c-p.rmcdn.net/5479c8026bbe3ca75cc0a82e/3936815/Image-4c796c76-d0a8-48d4-a692-f663aba72ef2.jpg"},"cropW":2075,"cropH":3121.7359050445107,"cropX":0,"cropY":0,"originalW":2075,"originalH":3130,"scale":0.064578313253012,"pic_opacity":1,"border_size":0,"border_color":"ffffff","border_radius":0,"border_radius_max":false,"border_radius_tl":0,"border_radius_tr":0,"border_radius_bl":0,"border_radius_br":0,"border_radius_independent":false,"opacity":1,"x":-30,"y":1031,"w":134,"h":202,"z":305},"viewport_tablet_portrait":{},"__v":0},{"_id":"631f02bce633ea002e7847b9","wid":"631f02bce633ea002e7847b9","mag_num_id":3936815,"type":"text","x":0,"y":209,"w":455,"h":478,"version":3,"z":313,"name":"","animation":[],"bgColor":"ffffff00","blocks":[{"key":"7eegf","text":"Dasha Glukhova is a gallery photographer. \nShe shoots stories in a documentary and poetic way. \nShe works mostly on 35 mm film cameras, rarrelly on 120 mm film.  \n\nGlukhova graduated from MSU university in art criticism department and advertising fild. She has defended a Phd about Creative technoly of PSA. For 5 years she investigated the difference between the creative process and the artist`s work in the context of the issues of the of the visual language based on different cultural codes.","entityRanges":[],"depth":0},{"key":"8dito","text":"","entityRanges":[],"depth":0},{"key":"8vkk7","text":" After the period of theory study, Dasha entered MBA program of Amsterdam VU University.","entityRanges":[],"depth":0},{"key":"a56d9","text":"\nHer works are in collections: Russisk Center for Videnskab og Kultur (Denmark), Mogens Andersen Atelier (Denmark) and others.\n\nSelected clients:\nAgent Provocateur, Vogue, Coca-Cola, Vanityfair, Samsung, Nike, Pepsi, Bloch, Time Out Magazine.","entityRanges":[],"depth":0}],"blocksMeta":[{"key":"7eegf","data":{"textStyle":"style-6ce43b59-2a09-4c16-b026-d1e97113fd32"}},{"key":"8dito","data":{"textStyle":"style-6ce43b59-2a09-4c16-b026-d1e97113fd32"}},{"key":"8vkk7","data":{"textStyle":"style-6ce43b59-2a09-4c16-b026-d1e97113fd32"}},{"key":"a56d9","data":{"textStyle":"style-6ce43b59-2a09-4c16-b026-d1e97113fd32"}}],"columns":{"count":1,"gap":16},"styles":[{"key":"7eegf","type":"unstyled","inlineStyles":{"styles":[],"keys":[],"values":[]}},{"key":"8dito","type":"unstyled","inlineStyles":{"styles":[],"keys":[],"values":[]}},{"key":"8vkk7","type":"unstyled","inlineStyles":{"styles":[],"keys":[],"values":[]}},{"key":"a56d9","type":"unstyled","inlineStyles":{"styles":[],"keys":[],"values":[]}}],"verticalAlign":"top","viewport_phone_portrait":{"styles":[{"key":"7eegf","type":"unstyled","inlineStyles":{"styles":[{"offset":0,"length":496,"styles":["0;0"]}],"keys":["FONT_SIZE"],"values":["16"]}},{"key":"8dito","type":"unstyled","inlineStyles":{"styles":[],"keys":[],"values":[]}},{"key":"8vkk7","type":"unstyled","inlineStyles":{"styles":[],"keys":[],"values":[]}},{"key":"a56d9","type":"unstyled","inlineStyles":{"styles":[{"offset":0,"length":242,"styles":["0;0"]}],"keys":["FONT_SIZE"],"values":["16"]}}],"bgColor":"ffffff00","columns":{"count":1,"gap":16},"blocksMeta":[{"key":"7eegf","data":{"textStyle":"paragraph-cc86f006-f290-4885-8700-d1d7101cd5a5","lineHeight":19}},{"key":"a56d9","data":{"textStyle":"paragraph-cc86f006-f290-4885-8700-d1d7101cd5a5","lineHeight":19}},{"key":"8dito","data":{"textStyle":"style-6ce43b59-2a09-4c16-b026-d1e97113fd32"}},{"key":"8vkk7","data":{"textStyle":"style-6ce43b59-2a09-4c16-b026-d1e97113fd32"}}],"entityMap":{},"x":-28,"y":197,"w":364,"h":354,"z":306,"animation":[]},"viewport_tablet_portrait":{"styles":[{"key":"7eegf","type":"unstyled","inlineStyles":{"styles":[],"keys":[],"values":[]}},{"key":"8dito","type":"unstyled","inlineStyles":{"styles":[],"keys":[],"values":[]}},{"key":"8vkk7","type":"unstyled","inlineStyles":{"styles":[],"keys":[],"values":[]}},{"key":"a56d9","type":"unstyled","inlineStyles":{"styles":[],"keys":[],"values":[]}}],"bgColor":"ffffff00","columns":{"count":1,"gap":16},"blocksMeta":[{"key":"7eegf","data":{"textStyle":"paragraph-cc86f006-f290-4885-8700-d1d7101cd5a5","align":"align-justify","paddings":{"bottom":0},"lineHeight":16}},{"key":"a56d9","data":{"textStyle":"paragraph-cc86f006-f290-4885-8700-d1d7101cd5a5","lineHeight":16}},{"key":"8dito","data":{"textStyle":"style-6ce43b59-2a09-4c16-b026-d1e97113fd32"}},{"key":"8vkk7","data":{"textStyle":"style-6ce43b59-2a09-4c16-b026-d1e97113fd32"}}],"entityMap":{},"x":28,"y":105,"w":384,"h":734,"z":332,"animation":[]},"entityMap":{},"flags":{"updatedLinks":true},"text":"","originId":"60056e1cb977ea008ac4c956","__v":0},{"_id":"6367d0d38b28ad001ad1a5eb","wid":"6367d0d38b28ad001ad1a5eb","mag_num_id":3936815,"type":"text","x":519,"y":1273,"w":486,"h":400,"version":3,"verticalAlign":"top","textDirection":"LTR","autosize":true,"blocks":[{"key":"4lru7","text":"ARTIST STATEMENT \n\nDaria strives to maintain excitability, to look for beauty and romantic moments in everyday life. Nature or people in the frames have notes of nostalgia. Each frame seems to have its own special additional color, air and aura around, its own glow and instability. Which emphasizes the uniqueness. \nDaria photographed a lot of people at the beginning of her career. She has a personal photo project that she has been shooting for 8 years traveling around the world with her son, she takes pictures of him in the arms of flight attendants. During covid, Daria began to shoot fewer people, but more nature and air, trying to convey the smell of the moment. The latest works are dedicated to nature in its essence.\n\n","entityRanges":[{"offset":448,"length":47,"key":0},{"offset":673,"length":16,"key":1}],"depth":0}],"styles":[{"key":"4lru7","type":"unstyled","inlineStyles":{"styles":[{"offset":0,"length":729,"styles":["0;0"]},{"offset":673,"length":17,"styles":["1;1"]}],"keys":["TRANSFORM","SHADOW"],"values":["uppercase","true;2;2;4;00000064;none;0.5;0.5"]}}],"entityMap":{"0":{"type":"LINK","mutability":"MUTABLE","data":{"url":"https://glukhova-dasha.com/savva/","anchorPosition":0,"type":"URL","target":"_blank","linkStyle":"link-27106f4a-1b0c-4a4d-9221-8024e7b69ce9","id":"2rqo6"}},"1":{"type":"LINK","mutability":"MUTABLE","data":{"url":"https://glukhova-dasha.com/breathe/","anchorPosition":0,"type":"URL","target":"_blank","linkStyle":"link-27106f4a-1b0c-4a4d-9221-8024e7b69ce9","id":"6033q"}}},"flags":{"baseline":true,"calculatedLineHeight":true,"updatedLinks":true,"newListPosition":true},"z":314,"blocksMeta":[{"key":"4lru7","data":{"sizesLinkedStatus":true,"textStyle":"style-6ce43b59-2a09-4c16-b026-d1e97113fd32","paddings":{"left":0}}}],"name":"","text":"","viewport_phone_portrait":{"styles":[{"key":"4lru7","type":"unstyled","inlineStyles":{"styles":[],"keys":[],"values":[]}}],"blocksMeta":[{"key":"4lru7","data":{"sizesLinkedStatus":true,"textStyle":"paragraph-cc86f006-f290-4885-8700-d1d7101cd5a5"}}],"entityMap":{"0":{"type":"LINK","data":{"url":"https://glukhova-dasha.com/savva/","anchorPosition":0,"type":"URL","target":"_blank","linkStyle":"link-27106f4a-1b0c-4a4d-9221-8024e7b69ce9","id":"2rqo6"},"mutability":"MUTABLE"},"1":{"type":"LINK","data":{"url":"https://glukhova-dasha.com/breathe/","anchorPosition":0,"type":"URL","target":"_blank","linkStyle":"link-27106f4a-1b0c-4a4d-9221-8024e7b69ce9","id":"6033q"},"mutability":"MUTABLE"}},"x":-28,"y":1648,"w":352,"h":342,"z":307},"viewport_tablet_portrait":{"styles":[{"key":"4lru7","type":"unstyled","inlineStyles":{"styles":[{"offset":0,"length":731,"styles